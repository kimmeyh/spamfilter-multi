{
  "_comment": "Project-level Claude Code settings shared across the team. Machine-specific overrides go in .claude/settings.local.json (gitignored).",
  "permissions": {
    "deny": [
      "Read(//0[!0-9]*.md)",
      "Read(//0[!0-9]*.txt)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${CLAUDE_PROJECT_DIR}\\.claude\\hooks\\block-carry-forward-stash.ps1\"",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${CLAUDE_PROJECT_DIR}\\.claude\\hooks\\sprint-auto-advance.ps1\"",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
