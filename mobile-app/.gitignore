# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.buildlog/

# WinWright transient outputs (selector-probe scratch + per-step failure screenshots).
# Scoped to the winwright test dir and the scripts dir (where the runner writes
# step_*_fail.png) so unrelated assets with similar names are not ignored.
test/winwright/_probe_*.json
test/winwright/step_*_fail.png
scripts/step_*_fail.png
.history
.svn/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# VS Code related
.vscode/

# F118 (Sprint 47): the archived pre-Sprint-37 Android tree keeps a live Gradle
# build cache that re-dirties the working tree on every open (transient .lock,
# .bin, and .properties files under .gradle/). These are build artifacts, never
# source, and were committed by accident (commit e925855). Ignore the whole
# .gradle/ cache under any android_legacy_* snapshot.
android_legacy_*/.gradle/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
/build/

# Sprint 37 F52 Phase 1: env-specific Windows variant build artifacts
# (Release-Dev/MyEmailSpamFilter-Dev.exe, Release-Prod/MyEmailSpamFilter.exe).
# Lives outside /build/ so `flutter clean` does not wipe across builds.
/dist/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

