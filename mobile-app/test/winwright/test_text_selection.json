{
  "version": "1",
  "appId": "",
  "mode": "test",
  "attachTitle": "MyEmailSpamFilter",
  "description": "Text selection / navigation reachability (ported to testCases schema 2026-06-05, ADR-0037). Opens Help from the home top-bar, returns, then opens Manage Rules (account-scoped) where rule-pattern text is rendered, then returns home. Action-only: reaching each screen proves its content rendered. Read-only. Verified against live UI 2026-06-05.",
  "runConfig": {
    "captureScreenshots": false,
    "screenshotFormat": "png",
    "screenshotOnFailureOnly": false,
    "continueOnFailure": false,
    "stepTimeoutMs": 15000,
    "maxFailures": 0
  },
  "testCases": [
    {
      "id": "TXT-1",
      "title": "Help screen reachable from home and returns",
      "steps": [
        { "tool": "ww_click", "selector": "type=Button[name='Help']" },
        { "tool": "ww_invoke", "selector": "type=Button[name='Back']" }
      ]
    },
    {
      "id": "TXT-2",
      "title": "Manage Rules renders rule-pattern text",
      "steps": [
        { "tool": "ww_click", "selector": "type=Button[name='Settings']" },
        { "tool": "ww_click", "selector": "type=Button[name*='kimmeyharold@aol.com']" },
        { "tool": "ww_click", "selector": "type=Button[name='Manage Rules']" },
        { "tool": "ww_invoke", "selector": "type=Button[name='Back']" },
        { "tool": "ww_invoke", "selector": "type=Button[name='Back']" }
      ]
    }
  ]
}
